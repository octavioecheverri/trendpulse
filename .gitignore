# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# private business docs (revenue projections, strategy) — hide contents by default
/docs/*
# ...but dev specs and setup guides should be versioned
!/docs/superpowers/
!/docs/SETUP.md

# claude / agent artifacts
CLAUDE.md
AGENTS.md
.claude-mem/

# playwright
/playwright-report/
/test-results/
